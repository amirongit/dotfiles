# font-family = CaskaydiaCove Nerd Font
# font-family-bold = CaskaydiaCove Nerd Font
# font-family-italic = CaskaydiaCove Nerd Font
# font-family-bold-italic = CaskaydiaCove Nerd Font
# font-style = Regular
# font-style-bold = SemiBold
# font-style-italic = Italic
# font-style-bold-italic = SemiBold Italic
# font-feature = ss01, ss02, ss03, ss20

# simple
# font-family = Agave Nerd Font
# font-family-bold = Agave Nerd Font
# font-family-italic = Agave Nerd Font
# font-family-bold-italic = Agave Nerd Font
# font-style = Regular
# font-style-bold = Regular
# font-style-italic = Regular
# font-style-bold-italic = Regular
