language = en

# jetbrains mono
font-family = JetBrainsMono Nerd Font
font-family-bold = JetBrainsMono Nerd Font
font-family-italic = JetBrainsMono Nerd Font
font-family-bold-italic = JetBrainsMono Nerd Font
font-style = Medium
font-style-bold = SemiBold
font-style-italic = Medium Italic
font-style-bold-italic = SemiBold Italic
font-feature = cv02, cv03, cv04, cv05, cv06, cv07, cv08, cv11, cv14, cv15, cv16, cv17, cv18, cv19, cv20

# fira code
# font-family = FiraCode Nerd Font
# font-family-bold = FiraCode Nerd Font
# font-family-italic = FiraCode Nerd Font
# font-family-bold-italic = FiraCode Nerd Font
# font-style = Medium
# font-style-bold = SemiBold
# font-style-italic = Medium
# font-style-bold-italic = SemiBold
# font-feature = cv01, cv02, zero, cv11, cv14, onum, cv16, cv29, cv31

# victor mono
# font-family = VictorMono Nerd Font
# font-family-bold = VictorMono Nerd Font
# font-family-italic = VictorMono Nerd Font
# font-family-bold-italic = VictorMono Nerd Font
# font-style = SemiBold
# font-style-bold = Bold
# font-style-italic = SemiBold Italic
# font-style-bold-italic = Bold Italic
# font-feature = ss01, ss04, ss06

